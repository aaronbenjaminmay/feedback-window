# Build-time config for the Vite frontend (plugin UI). Copy to .env before
# running `npm run build`, set for whichever backend this build should talk to.

# Verizon build:
# VITE_API_BASE_URL=https://feedback-window.vercel.app

# Agency build:
# VITE_API_BASE_URL=https://feedback-window-agency.vercel.app

VITE_API_BASE_URL=
